{
  "name": "whispersubtranslate",
  "version": "2.4.3",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "main.js",
  "scripts": {
    "start": "node scripts/start.js",
    "build": "electron-builder --publish never",
    "build-win": "npm run i18n:build && electron-builder --win",
    "postinstall": "node scripts/postinstall.js",
    "i18n:build": "node scripts/build-i18n.js",
    "i18n:check": "node scripts/build-i18n.js --check",
    "test": "node scripts/smoke-test.js",
    "test:e2e": "node scripts/e2e-smoke.js",
    "lint": "eslint *.js locales/*.js --fix",
    "lint:check": "eslint *.js locales/*.js",
    "check": "npm run i18n:check && npm run lint:check && npm test",
    "check:full": "npm run lint:check && npm test && npm run test:e2e",
    "format": "prettier --write \"*.js\" \"locales/*.js\" \"*.json\" \"*.html\" \"*.css\""
  },
  "keywords": [],
  "author": "GTPS Team",
  "license": "GPL-3.0",
  "description": "Whisper 기반 자막 추출·번역 도구 (whisper.cpp)",
  "build": {
    "appId": "com.whispersubtranslate.app",
    "productName": "WhisperSubTranslate",
    "afterPack": "scripts/afterPack.js",
    "directories": {
      "output": "dist2"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "build/icon.png",
      "assets/**",
      "locales/**",
      "renderer.js",
      "srt-cleanup.js",
      "translator-enhanced.js",
      "lib/**",
      "local-translator.js",
      "myMemoryTranslator.js",
      "scripts/postinstall.js",
      "node_modules/**/*",
      "!node_modules/**/{*.md,*.markdown,LICENSE*,test,tests,__tests__,*.map}",
      "!node_modules/@node-llama-cpp/linux-*/**",
      "!node_modules/@node-llama-cpp/win-arm64/**",
      "!node_modules/ffprobe-static/bin/linux/**",
      "!node_modules/ffprobe-static/bin/darwin/**",
      "!node_modules/7zip-bin/linux/**",
      "!node_modules/7zip-bin/mac/**",
      "!node_modules/7zip-bin/win/arm64/**",
      "!node_modules/7zip-bin/win/ia32/**"
    ],
    "extraResources": [
      {
        "from": "nya.wav",
        "to": "nya.wav"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**",
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**",
      "node_modules/7zip-bin/win/x64/**"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.png",
      "extraResources": [
        {
          "from": "whisper-cpp",
          "to": "whisper-cpp"
        },
        {
          "from": "ffprobe.exe",
          "to": "ffprobe.exe"
        }
      ]
    },
    "linux": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.png",
      "extraResources": [
        {
          "from": "whisper-cpp",
          "to": "whisper-cpp",
          "filter": [
            "whisper-cli",
            "cpu/**",
            "*.so*"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.png",
      "extraResources": [
        {
          "from": "whisper-cpp",
          "to": "whisper-cpp",
          "filter": [
            "whisper-cli",
            "cpu/**",
            "*.dylib"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhisperSubTranslate"
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.1.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "axios": "^1.6.0",
    "deepl-node": "^1.27.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "node-llama-cpp": "^3.18.1"
  },
  "optionalDependencies": {
    "@node-llama-cpp/linux-arm64": "3.18.1",
    "@node-llama-cpp/linux-armv7l": "3.18.1",
    "@node-llama-cpp/linux-x64": "3.18.1",
    "@node-llama-cpp/linux-x64-cuda": "3.18.1",
    "@node-llama-cpp/linux-x64-cuda-ext": "3.18.1",
    "@node-llama-cpp/linux-x64-vulkan": "3.18.1",
    "@node-llama-cpp/mac-arm64-metal": "3.18.1",
    "@node-llama-cpp/mac-x64": "3.18.1",
    "@node-llama-cpp/win-arm64": "3.18.1",
    "@node-llama-cpp/win-x64": "3.18.1",
    "@node-llama-cpp/win-x64-cuda": "3.18.1",
    "@node-llama-cpp/win-x64-cuda-ext": "3.18.1",
    "@node-llama-cpp/win-x64-vulkan": "3.18.1"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "@electron/get": "^5.0.0",
    "temp": {
      "rimraf": "^6.1.3"
    }
  }
}
